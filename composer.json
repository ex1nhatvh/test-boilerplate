{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": [
        "framework",
        "laravel"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "ext-ldap": "*",
        "laravel/framework": "^12.0",
        "exceedone/exment": "@dev",
        "exceedone/open-admin-core": "@dev",
        "aacotroneo/laravel-saml2": "^2.1",
        "doctrine/dbal": "^4.4",
        "exment-git/spout": "^4.0",
        "guzzlehttp/guzzle": "^7.10",
        "intervention/image": "^2.7",
        "laravel/browser-kit-testing": "^7.2",
        "laravel/helpers": "^1.8",
        "laravel/passport": "^12.4",
        "laravel/sanctum": "^4.2",
        "laravel/slack-notification-channel": "^3.7",
        "laravel/socialite": "^5.24",
        "laravel/tinker": "^2.10",
        "laravel/ui": "^4.6",
        "lcobucci/jwt": "^5.6",
        "mews/purifier": "^3.4",
        "myclabs/php-enum": "^1.8",
        "phpoffice/phpspreadsheet": "^1.30",
        "phpseclib/phpseclib": "^3.0",
        "pragmarx/google2fa": "^8.0",
        "simplesoftwareio/simple-qrcode": "^2.0",
        "spatie/flysystem-dropbox": "^3.0",
        "webpatser/laravel-uuid": "^4.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.24",
        "laravel/pint": "^1.26",
        "laravel/sail": "^1.51",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.8",
        "phpunit/phpunit": "^11.5",
        "spatie/laravel-ignition": "^2.9"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Exceedone\\Exment\\": "./exment/src",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ],
        "exment:test:init": [
            "Composer\\Config::disableProcessTimeout",
            "@php artisan exment:inittest --yes"
        ],
        "exment:test:browser": [
            "Composer\\Config::disableProcessTimeout",
            "@composer run exment:test:init",
            "@php vendor/bin/phpunit ./vendor/exceedone/exment/tests/Browser"
        ],
        "exment:test:feature": [
            "Composer\\Config::disableProcessTimeout",
            "@composer run exment:test:init",
            "@php vendor/bin/phpunit ./vendor/exceedone/exment/tests/Feature"
        ],
        "exment:test:unit": [
            "Composer\\Config::disableProcessTimeout",
            "@composer run exment:test:init",
            "@php vendor/bin/phpunit ./vendor/exceedone/exment/tests/Unit"
        ],
        "exment:test": [
            "Composer\\Config::disableProcessTimeout",
            "@composer run exment:test:init",
            "@php vendor/bin/phpunit ./vendor/exceedone/exment/tests"
        ]
    },
    "repositories": [
        {
            "type": "path",
            "url": "open-admin-core"
        },
        {
            "type": "path",
            "url": "exment"
        }
    ],
    "config": {
        "allow-plugins": {
            "kylekatarnls/update-helper": true
        },
        "audit": {
            "ignore": [
                "PKSA-y2cr-5h3j-g3ys"
            ]
        }
    }
}